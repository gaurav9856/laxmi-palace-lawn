# =====================================================
# Laxmi Palace Lawn — root .gitignore
# =====================================================

# Dependencies (re-installed via npm install)
**/node_modules/

# Build output
**/dist/
**/.angular/
**/out-tsc/
**/build/

# Environment & secrets — NEVER commit these
**/.env
**/.env.local
**/.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor & OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Misc
.cache/
coverage/
*.tsbuildinfo
